# Root-level common env vars — copy relevant sections into app-level .env.local files

# Supabase (server-only — never expose SERVICE_ROLE_KEY to browser)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Shopify
SHOPIFY_API_KEY=<your-api-key>
SHOPIFY_API_SECRET=<your-api-secret>
SHOPIFY_SCOPES=read_products,write_products
APP_URL=https://<your-tunnel-or-vercel-url>
SESSION_SECRET=<random-32-char-string>

# Widget
NEXT_PUBLIC_WIDGET_URL=https://<your-cdn-or-vercel-url>/widget.js
VITE_API_URL=https://<your-app-url>/apps/sqairinch
