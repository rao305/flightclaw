DEMO_USER_KEY=whatsapp:+16692602830

# Optional: enable aviationstack mapping adapter
AVIATIONSTACK_API_KEY=

# Optional: enable generic real flight status provider
FLIGHT_TRACKER_BASE_URL=
FLIGHT_TRACKER_API_KEY=

# Optional: enable real flightclaw price provider
FLIGHTCLAW_BASE_URL=
FLIGHTCLAW_API_KEY=

# Optional: persist to Postgres (otherwise uses in-memory DB)
DATABASE_URL=postgres://...

# Optional: send notifications to webhook transport
NOTIFY_WEBHOOK_URL=

# Optional: relay directly to OpenClaw bridge endpoint
OPENCLAW_RELAY_URL=http://localhost:8788/notify
OPENCLAW_RELAY_TOKEN=

# Optional: start local notifier bridge server
START_BRIDGE=false
BRIDGE_PORT=8788

# Optional: deterministic mock mode for reproducible demos/tests
MOCK_SEED=flighty-openclaw
# Must include timezone offset if set, e.g. 2026-03-01T12:00:00-05:00
MOCK_FIXED_NOW=
